{
    "name": "registro-ux/api",
    "description": "Professional Slim 4 REST API",
    "type": "project",
    "require": {
        "php": "^8.1",
        "dompdf/dompdf": "^3.1",
        "firebase/php-jwt": "^5.0",
        "illuminate/database": "^10.0",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "phpoffice/phpspreadsheet": "^5.5",
        "respect/validation": "^2.3",
        "robmorgan/phinx": "^0.13",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "tuupola/slim-jwt-auth": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "slim/slim": true
        },
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys", "PKSA-2kqm-ps5x-s4f5"]
        }
    }
}
